# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_7jor0peuhbUk@ep-gentle-bird-am1gtnaj-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ── HiveMQ Cloud ───────────────────────────────────────────────────────────────
HIVEMQ_HOST=f0ec5d4830754fa393f7de3a195e1aee.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=newtest
HIVEMQ_PASSWORD=Test@123

# Must match the prefix your Arduino/publisher uses.
# Your publisher sends to:  enviraLog/node-1/data
# So this must be:          enviraLog   (capital L — exact match required)
HIVEMQ_TOPIC_PREFIX=enviraLog

HIVEMQ_USE_TLS=true

# Leave this as the base name — a random suffix is appended automatically
# so every server restart gets a unique clientId (prevents reconnect loop)
HIVEMQ_CLIENT_ID=envirologapp-server

# ── Simulator ──────────────────────────────────────────────────────────────────
# false = only real Arduino data
# true  = simulator runs alongside Arduino (useful for dev/testing)
ENABLE_SIMULATOR=false
